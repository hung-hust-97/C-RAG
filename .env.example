### This is sample file of .env

###########################
### Server Configuration
###########################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='My Graph KB'
WEBUI_DESCRIPTION="Simple and Fast Graph Based RAG System"

########################################
### Document processing configuration
########################################
ENABLE_LLM_CACHE_FOR_EXTRACT=true

### Document processing output language: English, Chinese, French, German ...
SUMMARY_LANGUAGE=Vietnamese

### File upload size limit (in bytes)
### Default: 104857600 (100MB)
### Set to 0 or None for unlimited upload size
# MAX_UPLOAD_SIZE=104857600

### PDF decryption password for protected PDF files
# PDF_DECRYPT_PASSWORD=your_pdf_password_here

### Chunk size for document splitting, 500~1500 is recommended
# CHUNK_SIZE=1200
# CHUNK_OVERLAP_SIZE=100

########################################
### DeepSeek OCR Configuration
########################################
### OCR Engine Selection
### Valid values: auto, deepseek, tesseract, none
### - auto: Automatically select best available OCR engine (priority: deepseek > tesseract)
### - deepseek: Use DeepSeek OCR exclusively (requires DEEPSEEK_API_URL)
### - tesseract: Use Tesseract OCR exclusively
### - none: Disable all OCR processing
### Default: auto
### Validation: Must be one of: auto, deepseek, tesseract, none
DEEPSEEK_OCR_ENGINE=auto

### DeepSeek OCR API Endpoint
### HTTP/HTTPS URL for the DeepSeek OCR API service
### The API accepts PDF files via POST /ocr/pdf endpoint
### Default: http://10.1.6.52:8006/ocr/pdf
### Validation: Must start with http:// or https://
### Required when DEEPSEEK_OCR_ENGINE is set to 'deepseek' or 'auto'
DEEPSEEK_API_URL=http://10.1.6.52:8006/ocr/pdf

### DeepSeek OCR Request Timeout
### Maximum time (in seconds) to wait for OCR processing to complete
### Prevents long-running operations from blocking the system
### Default: 300 (5 minutes)
### Validation: Must be a positive integer
### Recommended: 300-600 for standard documents, 900+ for large PDFs
DEEPSEEK_OCR_TIMEOUT=300

### DeepSeek OCR Fallback to Tesseract
### Enable automatic fallback to Tesseract OCR if DeepSeek OCR fails
### When enabled, system attempts Tesseract OCR after DeepSeek failure
### When disabled, OCR failure raises an error immediately
### Default: true
### Validation: Must be true or false
### Recommended: true for production, false for debugging
DEEPSEEK_OCR_FALLBACK=true

### OCR Markdown Structure Preservation
### Preserve markdown structure from DeepSeek OCR output for better entity extraction
### DeepSeek OCR returns markdown-formatted text with headers, tables, and lists
### When enabled, markdown structure is maintained during preprocessing
### When disabled, markdown is converted to plain text
### Default: true
### Validation: Must be true or false
### Recommended: true for structured documents, false for simple text extraction
OCR_PRESERVE_MARKDOWN_STRUCTURE=true

### Example Configurations:
###
### 1. Production Setup (DeepSeek with Tesseract fallback):
###    DEEPSEEK_OCR_ENGINE=auto
###    DEEPSEEK_API_URL=http://10.1.6.52:8006/ocr/pdf
###    DEEPSEEK_OCR_TIMEOUT=300
###    DEEPSEEK_OCR_FALLBACK=true
###    OCR_PRESERVE_MARKDOWN_STRUCTURE=true
###
### 2. DeepSeek Only (No fallback):
###    DEEPSEEK_OCR_ENGINE=deepseek
###    DEEPSEEK_API_URL=http://10.1.6.52:8006/ocr/pdf
###    DEEPSEEK_OCR_TIMEOUT=600
###    DEEPSEEK_OCR_FALLBACK=false
###    OCR_PRESERVE_MARKDOWN_STRUCTURE=true
###
### 3. Tesseract Only (Legacy mode):
###    DEEPSEEK_OCR_ENGINE=tesseract
###    DEEPSEEK_OCR_FALLBACK=false
###    OCR_PRESERVE_MARKDOWN_STRUCTURE=false
###
### 4. OCR Disabled:
###    DEEPSEEK_OCR_ENGINE=none
###
### 5. Large Document Processing:
###    DEEPSEEK_OCR_ENGINE=auto
###    DEEPSEEK_API_URL=http://10.1.6.52:8006/ocr/pdf
###    DEEPSEEK_OCR_TIMEOUT=900
###    DEEPSEEK_OCR_FALLBACK=true
###    OCR_PRESERVE_MARKDOWN_STRUCTURE=true

###########################################################################
### LLM Configuration
### LLM_BINDING type: openai, ollama, lollms, azure_openai, aws_bedrock, gemini
###########################################################################
LLM_TIMEOUT=300

# LLM_BINDING=openai
# LLM_MODEL=gpt-4o
# LLM_BINDING_HOST=https://api.openai.com/v1
# LLM_BINDING_API_KEY=your_api_key

#######################################################################################
### Embedding Configuration (Should not be changed after the first file processed)
### EMBEDDING_BINDING: ollama, openai, azure_openai, jina, lollms, aws_bedrock
#######################################################################################
# EMBEDDING_TIMEOUT=30

# EMBEDDING_BINDING=openai
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIM=3072
# EMBEDDING_BINDING_HOST=https://api.openai.com/v1
# EMBEDDING_BINDING_API_KEY=your_api_key

####################################################################
### WORKSPACE sets workspace name for all storage types
####################################################################
# WORKSPACE=space1

############################
### Data storage selection
############################
### Default storage (Recommended for small scale deployment)
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
# LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

